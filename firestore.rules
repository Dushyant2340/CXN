rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidChatSession(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'messages', 'createdAt']) &&
             data.id is string &&
             data.userId == request.auth.uid &&
             data.title is string &&
             data.title.size() <= 200 &&
             data.messages is list &&
             data.createdAt is number;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Chat Sessions
    match /sessions/{sessionId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                    isValidId(sessionId) && 
                    isValidChatSession(request.resource.data);
      
      allow update: if isSignedIn() && 
                    isOwner(resource.data.userId) &&
                    isValidChatSession(request.resource.data) &&
                    request.resource.data.userId == resource.data.userId &&
                    request.resource.data.createdAt == resource.data.createdAt;
                    
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }
  }
}
